# Backend API base URL (no trailing slash). Used by Axios.
# Prefer this name; VITE_API_BASE_URL_PRODUCTION is also supported as a fallback.
VITE_API_BASE_URL=https://a2zbackend.a2zitem.com/api

# Optional: request timeout in ms (default 30000)
# VITE_API_TIMEOUT=30000

# Optional dev-only: enable Vite proxy to avoid CORS. Set apiClient base to /api and:
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# Legacy fallback (same as VITE_API_BASE_URL if you use only one)
# VITE_API_BASE_URL_PRODUCTION=

# Optional: query param names for GET .../product-list/ (defaults match a2z backend)
# VITE_API_PRODUCT_SORT_PARAM=sort
# VITE_API_PRODUCT_PAGE_PARAM=page
# VITE_API_PRODUCT_PAGE_SIZE_PARAM=perPage
# VITE_API_PRODUCT_PRICE_MIN_PARAM=priceMin
# VITE_API_PRODUCT_PRICE_MAX_PARAM=priceMax
# VITE_API_PRODUCT_AVAILABILITY_PARAM=availability
# VITE_API_PRODUCT_SUBCATEGORIES_PARAM=subcategories
# VITE_API_PRODUCT_BRAND_PARAM=brandId
# VITE_API_PRODUCT_CATEGORY_PARAM=category
